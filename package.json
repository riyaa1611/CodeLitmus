{
  "name": "codelitmus",
  "displayName": "CodeLitmus — Do You Understand Your Own Code?",
  "description": "AI-powered codebase understanding assessment. Stop vibe coding blindly — find out what you actually know.",
  "version": "0.1.1",
  "publisher": "RiyaGaur",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Testing", "Education", "Other"],
  "keywords": ["vibe coding", "code understanding", "quiz", "ai", "assessment", "audit", "learning"],
  "activationEvents": [
    "workspaceContains:**/*.ts",
    "workspaceContains:**/*.tsx",
    "workspaceContains:**/*.js",
    "workspaceContains:**/*.jsx",
    "workspaceContains:**/*.py",
    "workspaceContains:package.json",
    "workspaceContains:requirements.txt",
    "workspaceContains:pyproject.toml"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/riyaa1611/CodeLitmus"
  },
  "contributes": {
    "commands": [
      { "command": "codelitmus.scanWorkspace", "title": "CodeLitmus: Scan Workspace" },
      { "command": "codelitmus.startQuiz", "title": "CodeLitmus: Start Quiz", "icon": "$(beaker)" },
      { "command": "codelitmus.resetProgress", "title": "CodeLitmus: Reset Progress" },
      { "command": "codelitmus.startFocusedQuiz", "title": "CodeLitmus: Quiz on Current File" },
      { "command": "codelitmus.showReport", "title": "CodeLitmus: Show Report" },
      { "command": "codelitmus.showDangerZones", "title": "CodeLitmus: Show Danger Zones" },
      { "command": "codelitmus.setApiKey", "title": "CodeLitmus: Set OpenRouter API Key" },
      { "command": "codelitmus.resetScores", "title": "CodeLitmus: Reset All Scores" },
      { "command": "codelitmus.pinCurrentFile", "title": "CodeLitmus: Pin File for Quiz Focus" },
      { "command": "codelitmus.unpinFile", "title": "CodeLitmus: Unpin File" },
      { "command": "codelitmus.startPinnedQuiz", "title": "CodeLitmus: Quiz Pinned Files Only" },
      { "command": "codelitmus.exportScores", "title": "CodeLitmus: Export Scores (Team)" },
      { "command": "codelitmus.importScores", "title": "CodeLitmus: Import Team Scores" }
    ],
    "configuration": {
      "title": "CodeLitmus",
      "properties": {
        "codelitmus.llmModel": {
          "type": "string",
          "default": "deepseek/deepseek-chat-v3-0324:free",
          "description": "OpenRouter model ID for quiz generation. Browse free models at https://openrouter.ai/models?q=free",
          "order": 1
        },
        "codelitmus.questionsPerSession": {
          "type": "number",
          "default": 10,
          "minimum": 3,
          "maximum": 15,
          "description": "Number of questions per quiz session"
        },
        "codelitmus.difficultyOverride": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 5,
          "description": "Fixed quiz difficulty (1=Easy, 3=Normal, 5=Hard). Set to 0 to always prompt."
        },
        "codelitmus.autoScanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan workspace when opened"
        },
        "codelitmus.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLitmus CodeLens annotations above functions"
        },
        "codelitmus.supportedLanguages": {
          "type": "array",
          "default": ["typescript", "javascript", "python"],
          "description": "Languages to analyze"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codelitmus",
          "title": "CodeLitmus",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "codelitmus": [
        {
          "id": "codelitmus.fileScores",
          "name": "Understanding Scores"
        },
        {
          "id": "codelitmus.dangerZones",
          "name": "Danger Zones"
        },
        {
          "id": "codelitmus.pinnedFiles",
          "name": "Pinned Focus Files"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "codelitmus.startQuiz",
          "group": "navigation",
          "when": "workspaceFolderCount > 0"
        }
      ],
      "view/item/context": [
        {
          "command": "codelitmus.startFocusedQuiz",
          "when": "view == codelitmus.fileScores",
          "group": "codelitmus"
        },
        {
          "command": "codelitmus.unpinFile",
          "when": "view == codelitmus.pinnedFiles && viewItem == codelitmusPinnedFile",
          "group": "codelitmus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codelitmus.startQuiz",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "codelitmus.showReport",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "workspaceFolderCount > 0"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
